#!/bin/sh
# pre-commit guard — FIVE gates, all BLOCK the commit on failure:
#   1. Tenet 11 / ADR 015 — repo-integrity (FAST subset, Drive-sync corruption).
#   2. Tenet 14 (Detect) / AGENTS.md secrets rule — secret-scan (gitleaks).
#   3. Tenet 16 / COE 2026-06-10 — STATUS.md must stay a snapshot, not a log.
#   4. Tenet 10 / ADR 033 — operating-contract prose must match contract/*.yaml.
#   5. Tenet 2 / ADR 018 — editor pointer files carry zero canonical content.
#
# Git runs hooks through its bundled POSIX sh (even on Windows), so this shim is
# portable. Installed by scripts/install-hooks.ps1 as a COPY, not a symlink
# (tenet 3: symlinks are Windows-hostile). Hooks live in .git/, which is not
# versioned, so re-run install-hooks after any re-clone.

repo="$(git rev-parse --show-toplevel)"

# ---------------------------------------------------------------------------
# Gate 1 — repo-integrity (Tenet 11 / ADR 015).
# Fast subset = conflicted-copy + stale index.lock only (no fsck) so commits
# stay quick. Delegates to the PowerShell check (the Drive-sync risk is a
# Windows concern).
# ---------------------------------------------------------------------------
script="$repo/scripts/check-repo-health.ps1"
if [ ! -f "$script" ]; then
  echo "pre-commit: $script not found; skipping repo-health check (Tenet 11)." >&2
else
  if command -v powershell >/dev/null 2>&1; then
    ps="powershell"
  elif command -v pwsh >/dev/null 2>&1; then
    ps="pwsh"
  else
    ps=""
    echo "pre-commit: PowerShell not found; skipping repo-health check (Tenet 11)." >&2
  fi

  if [ -n "$ps" ]; then
    "$ps" -NoProfile -ExecutionPolicy Bypass -File "$script" -Fast -RepoList "$repo"
    status=$?
    if [ "$status" -ne 0 ]; then
      echo "" >&2
      echo "pre-commit BLOCKED: repo integrity check failed (Tenet 11 / ADR 015)." >&2
      echo "Do NOT hand-repair. Re-clone from GitHub and re-apply work." >&2
      echo "(To bypass in a known-safe case: git commit --no-verify)" >&2
      exit $status
    fi
  fi
fi

# ---------------------------------------------------------------------------
# Gate 2 — secret-scan (Tenet 14 Detect / AGENTS.md secrets rule).
# "No secrets in git" must be a DETERMINISTIC gate, not just a prose rule. We
# scan only STAGED changes (fast) with gitleaks. If gitleaks is missing we BLOCK
# (a security gate that silently no-ops is worse than one that asks to be set up)
# — install it once via scripts/install-hooks.ps1 (or `winget install
# Gitleaks.Gitleaks`) and restart the shell so it lands on PATH.
# ---------------------------------------------------------------------------
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "" >&2
  echo "pre-commit BLOCKED: gitleaks not found on PATH (secret-scan gate)." >&2
  echo "Install it once:  winget install Gitleaks.Gitleaks   (or re-run scripts/install-hooks.ps1)," >&2
  echo "then open a NEW shell so it lands on PATH." >&2
  echo "(To bypass in a known-safe case: git commit --no-verify)" >&2
  exit 1
fi

if [ -f "$repo/.gitleaks.toml" ]; then
  gitleaks git --staged --no-banner --redact --config "$repo/.gitleaks.toml" "$repo"
else
  gitleaks git --staged --no-banner --redact "$repo"
fi
glstatus=$?
if [ "$glstatus" -ne 0 ]; then
  echo "" >&2
  echo "pre-commit BLOCKED: gitleaks found a potential secret in your STAGED changes." >&2
  echo "Do NOT commit secrets. Move the value into infra/.env (gitignored) + Bitwarden." >&2
  echo "If it is a genuine false positive, add a NARROW allowlist to .gitleaks.toml." >&2
  echo "(To bypass in a known-safe case: git commit --no-verify)" >&2
  exit $glstatus
fi

# ---------------------------------------------------------------------------
# Gate 3 — STATUS.md snapshot shape (Tenet 16 / COE 2026-06-10).
# STATUS.md is overwritten each session; history belongs in BUILD-LOG.md. This
# blocks the commit when STATUS.md is accreting "Prior update" blocks or
# duplicate session sections (the drift that made it a second log).
# ---------------------------------------------------------------------------
status_gate="$repo/scripts/check_status_snapshot.py"
status_file="$repo/docs/planning/STATUS.md"
if [ -f "$status_gate" ] && [ -f "$status_file" ]; then
  python "$status_gate" "$status_file"
  ssstatus=$?
  if [ "$ssstatus" -ne 0 ]; then
    echo "" >&2
    echo "pre-commit BLOCKED: STATUS.md is drifting from snapshot to log (tenet 16)." >&2
    echo "Overwrite STATUS.md; append history to the private BUILD-LOG.md instead." >&2
    echo "(To bypass in a known-safe case: git commit --no-verify)" >&2
    exit $ssstatus
  fi
fi

# ---------------------------------------------------------------------------
# Gate 4 — operating-contract render freshness (Tenet 10 / ADR 033).
# The tenets / practices / DoD sections of AGENTS.md + docs/tenets.md are
# GENERATED from contract/*.yaml (single structured source). Block the commit
# when the prose has drifted from the YAML — drift becomes impossible by
# construction. Skips cleanly if PyYAML or the script is absent.
# ---------------------------------------------------------------------------
render_gate="$repo/scripts/render_contract.py"
if [ -f "$render_gate" ]; then
  python "$render_gate" --check
  rcstatus=$?
  if [ "$rcstatus" -ne 0 ]; then
    echo "" >&2
    echo "pre-commit BLOCKED: operating-contract docs are stale vs contract/*.yaml (ADR 033)." >&2
    echo "Run:  python scripts/render_contract.py   then stage the regenerated files." >&2
    echo "(To bypass in a known-safe case: git commit --no-verify)" >&2
    exit $rcstatus
  fi
fi

# ---------------------------------------------------------------------------
# Gate 5 — editor pointer-file purity (Tenet 2 / ADR 018).
# alwaysApply Cursor rules + CLAUDE.md must stay thin pointers ("read AGENTS.md"),
# never a copy of the tenets/DoD (closes COE 2026-06-07-cursor-rule-drift).
# ---------------------------------------------------------------------------
pointer_gate="$repo/scripts/check_pointer_purity.py"
if [ -f "$pointer_gate" ]; then
  python "$pointer_gate"
  pgstatus=$?
  if [ "$pgstatus" -ne 0 ]; then
    echo "" >&2
    echo "pre-commit BLOCKED: an editor pointer file is drifting into content (ADR 018)." >&2
    echo "Strip it back to frontmatter + 'read AGENTS.md'; content lives only in AGENTS.md." >&2
    echo "(To bypass in a known-safe case: git commit --no-verify)" >&2
    exit $pgstatus
  fi
fi

exit 0
