# Copy to .env (gitignored) and fill in. Generate secrets, never reuse the
# placeholders. Read by docker-compose, the Mem0 server, and Caddy.
#   cp .env.example .env

# ---- Domain & TLS (read by Caddy) ----------------------------------------
DOMAIN=example.com                       # TODO: registered domain (TBD); must match terraform domain_name
ACME_EMAIL=you@example.com               # Let's Encrypt registration/expiry notices

# CORS origin the API trusts + the URL the dashboard's browser bundle calls.
# In prod these are your real subdomains; locally they're localhost.
DASHBOARD_URL=https://dash.example.com
DASHBOARD_API_URL=https://memory.example.com

# ---- API auth (built into the Mem0 server) -------------------------------
JWT_SECRET=REPLACE_ME                    # openssl rand -base64 48
ADMIN_API_KEY=REPLACE_ME                 # openssl rand -base64 32
AUTH_DISABLED=false                      # never true in production

# ---- Admin-UI basic auth (Caddy, for dash. and graph.) -------------------
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=REPLACE_ME               # docker run --rm caddy:2-alpine caddy hash-password

# ---- Datastores ----------------------------------------------------------
POSTGRES_USER=mem0
POSTGRES_PASSWORD=REPLACE_ME             # openssl rand -base64 24
POSTGRES_DB=mem0
NEO4J_PASSWORD=REPLACE_ME                # openssl rand -base64 24  (Neo4j user is always "neo4j")

# ---- Models / providers --------------------------------------------------
# SINGLE provider for both stages — OpenAI (ADR 013, supersedes ADR 002; tenets
# 7 & 9). One key, one bill, Mem0's default config, zero extra wiring.
#   (1) extraction LLM:  gpt-5-mini   (~₹90/mo; Mem0's default; chosen for
#                        structured-output reliability, not cost — see ADR 013)
#   (2) embeddings:      text-embedding-3-small   (Mem0 default; ADR 011)
# Cheaper OpenAI fallback if cost ever bites: gpt-4.1-nano (~₹35/mo) — one-line
# swap, but higher JSON-schema error rate on extraction/categorizer (ADR 013).
OPENAI_API_KEY=sk-REPLACE_ME             # OpenAI key — serves BOTH stages
MEM0_DEFAULT_LLM_MODEL=gpt-5-mini
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
#
# ── Swappable alternatives (tenet 2) ──────────────────────────────────────
# DeepSeek V4 Flash extraction (cheaper output, but a 2nd provider + the gotcha
# below; literal id deepseek-v4-flash, NOT the deprecated deepseek-chat):
#   DEEPSEEK_API_KEY=sk-REPLACE_ME
#   DEEPSEEK_BASE_URL=https://api.deepseek.com
#   MEM0_DEFAULT_LLM_MODEL=deepseek-v4-flash
# ⚠️ GOTCHA: Mem0 uses ONE OpenAI client for both stages, so you can't just point
# OPENAI_BASE_URL at DeepSeek (the embedder would hit DeepSeek, which has no
# embeddings endpoint, and fail). A split needs a per-component Mem0 config
# (mounted config.json / MEMORY_CONFIG) setting the llm's base_url+key apart from
# the embedder's. This integration cost is exactly why ADR 013 stays single-provider.
#
# 🔮 STEADY STATE: point both stages at local Ollama on the Alienware (₹0 cost).

# ---- Telemetry -----------------------------------------------------------
MEM0_TELEMETRY=false                     # opt out of anonymous onboarding ping
